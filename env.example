# Copy to ".env" in this folder (never commit .env).
# Tokens: ConvertAPI dashboard → Integration → Authentication
# https://www.convertapi.com/a/authentication

# Which token to use: production (default) or sandbox
CONVERTAPI_ENV=production

# Production API token (unlimited / live billing as per your plan)
CONVERTAPI_SECRET=

# Sandbox token (limited free conversions for testing)
CONVERTAPI_SECRET_SANDBOX=

# Optional: EU endpoint
# CONVERTAPI_BASE_URI=https://eu-v2.convertapi.com/

# Preview rendering cap (fast /upload on Render, Coolify, Docker, etc.)
# Lower = faster server response after deploy. 0 = no PNG previews.
MAX_PREVIEW_PAGES=4
